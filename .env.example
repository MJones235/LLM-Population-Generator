# Environment Variables Template
# Copy this file to .env or secrets.env and add your actual API keys

# Azure OpenAI Configuration (primary - package now uses Azure OpenAI)
AZURE_OPENAI_API_KEY=your-azure-openai-key-here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_MODEL=gpt-4o-mini  # This should be your deployment name in Azure
AZURE_OPENAI_TEMPERATURE=0.7

# Anthropic Configuration (optional)  
# ANTHROPIC_API_KEY=your-anthropic-key-here
# ANTHROPIC_MODEL=claude-3-sonnet-20240229

# Ollama Configuration (for local models)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1:8b

# Generation Settings
DEFAULT_BATCH_SIZE=10
DEFAULT_TIMEOUT=60
ENABLE_STATS=true
